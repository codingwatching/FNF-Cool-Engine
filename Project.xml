<?xml version="1.0" encoding="utf-8"?>
<project>
	<!-- _________________________ Application Settings _________________________ -->

	<app title="Friday Night Funkin': Cool Engine" file="CoolEngine" packageName="com.coolTeam.coolEngine" package="com.coolTeam.coolEngine" main="Main" version="0.6.0B" company="CoolTeam" />

	<!--Switch Export with Unique ApplicationID and Icon-->
	<set name="APP_ID" value="0x0100f6c013bbc000" />

	<!--The flixel preloader is not accurate in Chrome. You can use it regularly if you embed the swf into a html file
		or you can set the actual size of your file manually at "FlxPreloaderBase-onUpdate-bytesTotal"-->
	<!-- <app preloader="Preloader" resizable="true" /> -->
	<app preloader="flixel.system.FlxPreloader" />

	<!--Minimum without FLX_NO_GAMEPAD: 11.8, without FLX_NO_NATIVE_CURSOR: 11.2-->
	<set name="SWF_VERSION" value="11.8" />

	<!-- ____________________________ Window Settings ___________________________ -->

	<!--These window settings apply to all targets-->
	<window width="1280" height="720" fps="120" background="#000000" hardware="true" vsync="false" />

	<!--HTML5-specific-->
	<window if="html5" resizable="true" />

	<!--Desktop-specific-->
	<window if="desktop" orientation="landscape" fullscreen="false" resizable="true" vsync="false" />

	<!--Mobile-specific-->
	<window if="mobile" orientation="landscape" fullscreen="true" width="1280" height="720" resizable="false" />

	<!--Android Configuration - Updated to modern API levels-->
	<android target-sdk-version="33" if="android" install-location="auto" />
	<android permission="android.permission.INTERNET" if="android" />
	<android permission="android.permission.ACCESS_NETWORK_STATE" if="android" />
	<android permission="android.permission.WAKE_LOCK" if="android" />
	<!-- Permisos de almacenamiento para leer mods de /sdcard/ -->
	<android permission="android.permission.READ_EXTERNAL_STORAGE" if="android" />
	<android permission="android.permission.WRITE_EXTERNAL_STORAGE" if="android" />
	
	<define name="mobileC" if="mobile" />
	<assets path="assets/images/hitbox" if="mobile" />

	<!--Switch-specific-->
	<window if="switch" orientation="landscape" fullscreen="true" width="1920" height="1080" resizable="false" />

	<!-- _____________________________ Path Settings ____________________________ -->

	<set name="BUILD_DIR" value="export/debug"   if="debug" />
	<set name="BUILD_DIR" value="export/release"  unless="debug" />
	<set name="BUILD_DIR" value="export/32bit"    if="32bit" />

	<classpath name="source" />
	
	<define name="PRELOAD_ALL"    unless="web" />
	<define name="NO_PRELOAD_ALL" unless="PRELOAD_ALL" />

	<library name="default" preload="true"  if="PRELOAD_ALL" />
	<library name="default" preload="false" if="NO_PRELOAD_ALL" />

	<library name="assets" preload="true"  if="PRELOAD_ALL" />
	<library name="assets" preload="false" if="NO_PRELOAD_ALL" />

	<section unless="BUILD">
		<assets path="assets/" rename="assets" exclude="*.ogg" if="web" />
		<assets path="assets/" rename="assets" exclude="*.mp3" unless="web" />
		<!-- Desktop/Linux/Switch: mods van sueltos junto al binario -->
		<assets path="mods" rename="mods" embed="false" unless="android" />
		<!-- Android: los mods base viajan dentro del APK como assets de solo lectura.
		     ModManager los copia al storage externo en el primer arranque. -->
		<assets path="mods" rename="assets/mods" embed="false" if="android" />
	</section>

	<!-- Windows -->
	<prebuild command="cmd /c if exist export\debug\windows\cpp\bin\mods xcopy /E /I /Y /Q export\debug\windows\cpp\bin\mods mods &gt;nul"   if="windows &amp;&amp; debug" />
	<prebuild command="cmd /c if exist export\release\windows\cpp\bin\mods xcopy /E /I /Y /Q export\release\windows\cpp\bin\mods mods &gt;nul" if="windows &amp;&amp; !debug" />

	<!-- Linux -->
	<prebuild command="bash -c 'if [ -d export/debug/linux/cpp/bin/mods ];   then cp -rn export/debug/linux/cpp/bin/mods/. mods/; fi'"   if="linux &amp;&amp; debug" />
	<prebuild command="bash -c 'if [ -d export/release/linux/cpp/bin/mods ]; then cp -rn export/release/linux/cpp/bin/mods/. mods/; fi'" if="linux &amp;&amp; !debug" />

	<assets path="plugins/" rename="" if="windows" />
	<assets path="dlls/"    rename="" if="windows" />
	
	<assets path="art/readme.txt" rename="do NOT readme.txt" />

	<assets path="CHANGELOG.md" />

	<define name="HSCRIPT_ALLOWED" />

	<!-- Font configuration: Fonts are embedded and should be referenced by their font family name in setFormat() -->
	<assets path="assets/fonts" embed="true" />
	
	<!-- ─── VSyncAPI: librerías OpenGL nativas ──────────────────────────────────
	     Linkea opengl32 en Windows y GL en Linux para wglSwapIntervalEXT /
	     glXSwapIntervalMESA. En macOS, CGL viene incluido en el framework
	     OpenGL que Lime ya enlaza. No afecta a HTML5/mobile.
	-->
	<dependency name="opengl32.lib" if="windows" />
	<dependency name="opengl32"     if="windows" />
	<dependency name="GL"           if="linux" />

	<!-- _______________________________ Libraries ______________________________ -->

	<haxelib name="openfl" />
	<haxelib name="lime" />
	<haxelib name="flixel" />
	<haxedef name="webgl" if="html5" />

	<!--In case you want to use the addons package-->
	<haxelib name="flixel-addons" />
	<haxelib name="hscript" />

	<!--In case you want to use the ui package-->
	<haxelib name="flixel-ui" />
	<haxelib name="faxe"     if="switch" />
	<haxelib name="actuate" />
	<haxelib name="discord_rpc" if="desktop" />

	<section if="cpp">
  		<haxelib name="hxvlc" if="desktop || mobile" />
	</section>

	<haxelib name="flixel-animate" />

	<!-- ______________________________ Haxedefines _____________________________ -->

	<!--Disable the Flixel core focus lost screen-->
	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />

	<!--Disable the Flixel core debugger. Automatically gets set whenever you compile in release mode!-->
	<haxedef name="FLX_NO_DEBUG" unless="debug" />

	<!--Enable this for Nape release builds for a serious performance improvement-->
	<haxedef name="NAPE_RELEASE_BUILD" unless="debug" />
	
	<!-- ─── Optimizaciones de release ──────────────────────────────────────────
	     -O3         : máxima optimización del compilador C++
	     -O2         : alternativa más segura en algunos toolchains
	     dce full    : elimina todo el código Haxe no alcanzado
	     no-traces   : elimina todos los trace() en release (ahorra CPU/IO)
	-->
	<haxedef name="no-deprecation-warnings" unless="debug" />
	<haxeflag name="-dce" value="full" unless="debug" />

	<!-- Optimización C++ agresiva en release (MSVC y GCC/Clang) -->
	<compilerflag value="/O2"  if="windows &amp;&amp; !debug" />
	<compilerflag value="-O3"  if="linux   &amp;&amp; !debug" />
	<compilerflag value="-O3"  if="mac     &amp;&amp; !debug" />

	<!-- Link-time optimization en release (reduce tamaño binario ~10-20%) -->
	<compilerflag value="/GL"    if="windows &amp;&amp; !debug" />
	<linkerFlag   value="/LTCG"  if="windows &amp;&amp; !debug" />
	<compilerflag value="-flto"  if="linux   &amp;&amp; !debug" />
	<compilerflag value="-flto"  if="mac     &amp;&amp; !debug" />

	<!-- ─── Compilación más rápida en debug ────────────────────────────────────
	     Desactiva optimizaciones del compilador para builds de desarrollo.
	     Reduce tiempo de compilación incremental significativamente.
	-->
	<compilerflag value="/Od" if="windows &amp;&amp; debug" />
	<compilerflag value="-O0" if="linux   &amp;&amp; debug" />
	<compilerflag value="-O0" if="mac     &amp;&amp; debug" />

	<!-- ─── Stack trace en release ─────────────────────────────────────────────
	     HXCPP_CHECK_POINTER:  convierte null pointer nativo en excepción Haxe
	                            capturable por CrashHandler en release.
	     openfl_enable_handle_error: despacha UncaughtErrorEvent en cpp.
	-->
	<haxedef name="HXCPP_CHECK_POINTER" />
	<haxedef name="openfl_enable_handle_error" />

	<!-- ─── Rendimiento de GC ───────────────────────────────────────────────────
	     HXCPP_GC_GENERATIONAL removido intencionalmente:
	     puede colectar FlxGraphics "vivos" sin referencias C++ fuertes
	     → bitmap=null en FlxDrawQuadsItem::render → crash.
	     El GC conservador (default) es obligatorio con el caché de dos capas.

	     HXCPP_LARGE_BLOCKS: pre-reserva bloques de heap más grandes,
	     reduce la frecuencia de GC durante gameplay intenso.
	-->
	<haxedef name="HXCPP_LARGE_BLOCKS" />

	<haxeflag name="--macro" value="WinMacroFix.apply()" if="windows" />

	<template path="templates/android" />

	<!-- _________________________________ Custom _______________________________ -->

	<!--Place custom nodes like icons here (higher priority to override the HaxeFlixel icon)-->
	
	<icon path="art/icon16.png" size="16" />
	<icon path="art/icon32.png" size="32" />
	<icon path="art/icon64.png" size="64" />
	<icon path="art/iconOG.png" />
</project>
