{
  "skippable": false,

  "sprites": {
    "red": {
      "type": "rect",
      "color": "0xFFff1b31",
      "width": 2,
      "height": 2,
      "x": -100,
      "y": -100,
      "scrollFactor": 0
    },
    "black": {
      "type": "rect",
      "color": "0xFF000000",
      "width": 2,
      "height": 2,
      "x": -100,
      "y": -100,
      "scrollFactor": 0
    },
    "senpaiEvil": {
      "type": "character",
      "image": "weeb/senpaiCrazy",
      "scale": 6,
      "center": true,
      "scrollFactor": 0,
      "antialiasing": true,
      "animations": [
        {
          "name": "idle",
          "prefix": "Senpai Pre Explosion",
          "fps": 24,
          "loop": false
        }
      ]
    }
  },

  "steps": [
    { "action": "add", "sprite": "red" },
    { "action": "add", "sprite": "black" },

    { "action": "fadeTimer", "sprite": "black", "target": 0, "step": 0.15, "interval": 0.3 },
    { "action": "remove", "sprite": "black" },

    { "action": "add", "sprite": "senpaiEvil", "alpha": 0 },
    { "action": "fadeTimer", "sprite": "senpaiEvil", "target": 1, "step": 0.15, "interval": 0.3 },

    { "action": "playAnim", "sprite": "senpaiEvil", "anim": "idle" },
    { "action": "playSound", "key": "sounds/Senpai_Dies", "volume": 1, "id": "dies" },

    { "action": "wait", "time": 3.2 },
    { "action": "cameraFade", "color": "WHITE", "duration": 1.6, "async": true },

    { "action": "waitSound", "id": "dies" },

    { "action": "remove", "sprite": "senpaiEvil" },
    { "action": "remove", "sprite": "red" },

    { "action": "cameraFade", "color": "WHITE", "duration": 0.01, "fadeIn": true },

    { "action": "end" }
  ]
}
